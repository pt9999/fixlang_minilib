module Minilib.Thread.Counter;
//module Main;

import AsyncTask;

type Counter = unbox struct {
    data: Var I64
};

namespace Counter {
    make: I64 -> IO Counter;
    make = |i64val| pure $ Counter {
        data: *Var::make(i64val)
    };

    get: Counter -> IO I64;
    get = |ctr| (
        ctr.@data.get
    );

    inc: Counter -> IO I64;
    inc = |ctr| (
        ctr.@data.lock(|i64val|
            ctr.@data.Var::set(i64val + 1);;
            pure $ i64val
        )
    );
}

