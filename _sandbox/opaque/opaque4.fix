module Main;

trait a: FooTrait {
    foo: [?s: ToString] a -> ?s;
}

impl I64: FooTrait {
    foo = |a| "I64";
}

impl U64: FooTrait {
    foo = |a| "U64";
}

print_foo: [a: FooTrait] a -> IO ();
print_foo = |a| (
    a.foo.to_string.println
);

main: IO ();
main = (
    print_foo(1);;
    print_foo(2_U64);;
    pure()
);
